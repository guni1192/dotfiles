{
  "$schema": "https://raw.githubusercontent.com/jetify-com/devbox/0.16.0/.schema/devbox.schema.json",
  "packages": [
    "neovim@0.12.2",
    "fzf@0.72.0",
    "ghq@1.9.4",
    "gh@2.88.1",
    "ripgrep@15.1.0",
    "kubectl@1.36.0",
    "kubernetes-helm@3.20.2",
    "krew@0.5.0",
    "kustomize@5.8.0",
    "kind@0.31.0",
    "stern@1.33.1",
    "nodejs@24.12.0",
    "tree-sitter@0.26.8",
    "gopls@0.21.1",
    "terraform-ls@0.38.6",
    "lua-language-server@3.18.1",
    "rust-analyzer@2026-04-13",
    "yq-go@4.53.2",
    "devcontainer@0.86.0",
    "gitleaks@8.30.1"
  ],
  "env": {
    "NPM_CONFIG_PREFIX": "$HOME/.local/npm-global",
    "PATH": "$HOME/.local/npm-global/bin:$PATH"
  },
  "shell": {
    "init_hook": [
      "command -v copilot-language-server >/dev/null 2>&1 || npm install -g @github/copilot-language-server@1.472.0"
    ]
  }
}
