{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "branchConcurrentLimit": 0,
  "enabledManagers": [
    "devbox"
  ],
  "packageRules": [
    {
      "matchManagers": ["devbox"],
      "matchPackageNames": ["google-cloud-sdk", "awscli2", "flarectl"],
      "enabled": false
    }
  ]
}
